<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Jungle Cat - Classic</title>
    <style>
        /* Layout Setup */
        body { margin: 0; overflow: hidden; background: #000; font-family: 'Arial Black', sans-serif; display: flex; flex-direction: column; height: 100vh; }
        
        #game-container { position: relative; flex-grow: 1; overflow: hidden; cursor: pointer; }
        canvas { display: block; width: 100%; height: 100%; }

        /* UI Overlays */
        #ui-layer {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; pointer-events: none;
        }

        #menu {
            pointer-events: auto; text-align: center; background: rgba(0, 31, 63, 0.9);
            padding: 40px; border: 4px solid #4DD0E1; border-radius: 25px;
            box-shadow: 0 0 20px rgba(77, 208, 225, 0.5);
        }

        /* Computer Friendly Buttons */
        button {
            background: #66BB6A; color: white; border: none; padding: 15px 50px;
            font-size: 28px; cursor: pointer; border-radius: 12px; margin: 10px;
            font-family: 'Arial Black'; box-shadow: 0 6px #2E7D32; transition: 0.2s;
        }
        button:hover { background: #81C784; transform: scale(1.05); }
        button:active { transform: translateY(4px); box-shadow: 0 2px #2E7D32; }

        #current-score { font-size: 100px; color: white; margin: 0; text-shadow: 5px 5px #000; visibility: hidden; z-index: 10; }
        #lives { position: absolute; top: 20px; left: 20px; font-size: 30px; color: #FFB300; text-shadow: 2px 2px #000; }
        #instructions { color: #4DD0E1; font-size: 14px; margin-top: 15px; font-family: sans-serif; }

        /* Banner Ad Area */
        #bottom-banner {
            width: 100%;
            height: 60px;
            background: #ffffff;
            color: #333;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            border-top: 3px solid #4DD0E1;
            z-index: 100;
            font-family: Arial, sans-serif;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div id="game-container">
        <div id="lives">❤❤</div>
        <div id="ui-layer">
            <h1 id="current-score">0</h1>
            
            <div id="menu">
                <h1 style="color:#FFB300; margin:0; font-size: 55px; letter-spacing: -2px;">JUNGLE CAT</h1>
                <p style="color:white; margin: 5px 0;">BEST: <span id="best-score">0</span></p>
                <button onclick="startGame()">START</button>
                <div id="instructions">SPACEBAR, CLICK, or TAP to Jump</div>
            </div>
        </div>
        <canvas id="game"></canvas>
    </div>

    <div id="bottom-banner">
        <span>ADVERTISEMENT: Check out the Neon Shop!</span> 
    </div>

    <script>
        const canvas = document.getElementById('game');
        const ctx = canvas.getContext('2d');
        const scoreEl = document.getElementById('current-score');
        const bestEl = document.getElementById('best-score');
        const menuEl = document.getElementById('menu');
        const livesEl = document.getElementById('lives');

        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight - 60;

        let gameState = 'MENU';
        let score = 0;
        let highscore = localStorage.getItem('flappyCat_Highscore') || 0;
        let lives = 2;
        let pipes = [];
        let gameSpeed = 3.8;
        let cat = { x: 80, y: 200, w: 45, h: 35, v: 0, g: 0.45 };
        bestEl.innerText = highscore;

        function startGame() {
            gameState = 'PLAYING';
            menuEl.style.display = 'none';
            scoreEl.style.visibility = 'visible';
            score = 0; 
            lives = 2; 
            pipes = []; 
            cat.y = canvas.height / 2; 
            cat.v = 0;
            gameSpeed = 3.8;
            updateUI();
        }

        function updateUI() {
            livesEl.innerText = "❤".repeat(Math.max(0, lives));
            scoreEl.innerText = score;
        }

        function triggerHit() {
            lives--;
            updateUI();
            if (lives <= 0) {
                if (score > highscore) {
                    highscore = score;
                    localStorage.setItem('flappyCat_Highscore', highscore);
                    bestEl.innerText = highscore;
                }
                gameState = 'MENU';
                menuEl.style.display = 'block';
                scoreEl.style.visibility = 'hidden';
            } else {
                pipes = [];
                cat.y = canvas.height / 2;
                cat.v = 0;
            }
        }

        function update() {
            if (gameState !== 'PLAYING') return;

            cat.v += cat.g;
            cat.y += cat.v;

            if (cat.y + cat.h > canvas.height || cat.y < 0) triggerHit();

            pipes.forEach((p, i) => {
                p.x -= gameSpeed;
                
                if (cat.x + 5 < p.x + 75 && cat.x + cat.w - 5 > p.x &&
                    (cat.y + 5 < p.topH || cat.y + cat.h - 5 > p.topH + 210)) {
                    triggerHit();
                }

                if (!p.passed && p.x + 75 < cat.x) {
                    p.passed = true; 
                    score++; 
                    updateUI();
                    if(score % 5 === 0) gameSpeed += 0.25; 
                }

                if (p.x < -100) pipes.splice(i, 1);
            });

            if (pipes.length === 0 || pipes[pipes.length-1].x < canvas.width - 350) {
                pipes.push({ 
                    x: canvas.width, 
                    topH: Math.random() * (canvas.height - 450) + 120, 
                    passed: false 
                });
            }
        }

        function draw() {
            let skyGrad = ctx.createLinearGradient(0, 0, 0, canvas.height);
            skyGrad.addColorStop(0, '#001F3F');
            skyGrad.addColorStop(1, '#0074D9');
            ctx.fillStyle = skyGrad;
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            pipes.forEach(p => {
                ctx.fillStyle = "#66BB6A";
                ctx.beginPath();
                ctx.roundRect(p.x, 0, 75, p.topH, [0, 0, 15, 15]);
                ctx.fill();
                ctx.beginPath();
                ctx.roundRect(p.x, p.topH + 210, 75, canvas.height, [15, 15, 0, 0]);
                ctx.fill();
            });

            ctx.save();
            ctx.translate(cat.x + cat.w/2, cat.y + cat.h/2);
            if (gameState === 'PLAYING') ctx.rotate(Math.min(Math.PI/3, Math.max(-Math.PI/4, cat.v * 0.07)));
            
            ctx.fillStyle = "#FFB300";
            ctx.shadowColor = "#FFB300";
            ctx.shadowBlur = 15;
            ctx.beginPath();
            ctx.ellipse(0, 0, 22, 18, 0, 0, Math.PI*2);
            ctx.fill();
            
            ctx.beginPath();
            ctx.moveTo(-15, -10); ctx.lineTo(-22, -28); ctx.lineTo(-6, -16);
            ctx.moveTo(15, -10); ctx.lineTo(22, -28); ctx.lineTo(6, -16);
            ctx.fill();
            
            ctx.fillStyle = "#333";
            ctx.beginPath(); ctx.arc(-8, -3, 3, 0, Math.PI*2); ctx.arc(8, -3, 3, 0, Math.PI*2); ctx.fill();
            ctx.restore();

            update();
            requestAnimationFrame(draw);
        }

        const flap = (e) => {
            if (gameState === 'PLAYING') {
                cat.v = -8;
                if (e && e.cancelable) e.preventDefault();
            }
        };

        window.addEventListener('mousedown', flap);
        window.addEventListener('touchstart', flap, {passive: false});
        window.addEventListener('keydown', (e) => { 
            if (e.code === 'Space' || e.code === 'ArrowUp') {
                flap(e);
            }
        });

        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight - 60;
        });

        draw();
    </script>
</body>
</html>
